{
  "name": "mfe-workspace",
  "version": "0.0.0",
  "scripts": {
    "install:host": "npm --prefix angular-host ci",
    "install:angular-mfe": "npm --prefix angular-mfe ci",
    "install:react": "npm --prefix react-mfe ci",
    "install:vue": "npm --prefix vue-mfe ci",
    "install:all": "npm ci && npm run install:host && npm run install:angular-mfe && npm run install:react && npm run install:vue",
    "start:host": "npm --prefix angular-host run start",
    "start:mfe1": "npm --prefix angular-mfe run start:mfe1",
    "start:mfe2": "npm --prefix angular-mfe run start:mfe2",
    "start:react": "npm --prefix react-mfe run start",
    "start:react-window": "npm --prefix react-mfe run start:window",
    "start:react-window-collision": "npm --prefix react-mfe run start:window-collision",
    "start:vue": "npm --prefix vue-mfe run start",
    "start:vue-window": "npm --prefix vue-mfe run start:window",
    "start:all": "concurrently -k \"npm run start:mfe1\" \"npm run start:mfe2\" \"npm run start:react\" \"npm run start:react-window\" \"npm run start:react-window-collision\" \"npm run start:vue\" \"npm run start:vue-window\" \"npm run start:host\"",
    "build:host": "npm --prefix angular-host run build",
    "build:mfe1": "npm --prefix angular-mfe run build:mfe1",
    "build:mfe2": "npm --prefix angular-mfe run build:mfe2",
    "build:react": "npm --prefix react-mfe run build",
    "build:react-window": "npm --prefix react-mfe run build:window",
    "build:react-window-collision": "npm --prefix react-mfe run build:window-collision",
    "build:vue": "npm --prefix vue-mfe run build",
    "build:vue-window": "npm --prefix vue-mfe run build:window",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down"
  },
  "private": true,
  "packageManager": "npm@11.4.2",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1"
  }
}
