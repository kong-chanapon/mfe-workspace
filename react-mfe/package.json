{
  "name": "react-mfe",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "npm run start:props",
    "start:props": "webpack serve --config webpack.props.config.js --mode development",
    "start:window": "webpack serve --config webpack.window.config.js --mode development",
    "start:window-collision": "webpack serve --config webpack.window.collision.config.js --mode development",
    "start:ax-element": "webpack serve --config webpack.ax.element.config.js --mode development",
    "build": "npm run build:all",
    "build:props": "webpack --config webpack.props.config.js --mode production",
    "build:window": "webpack --config webpack.window.config.js --mode production",
    "build:window-collision": "webpack --config webpack.window.collision.config.js --mode production",
    "build:ax-element": "webpack --config webpack.ax.element.config.js --mode production",
    "build:all": "npm run build:props && npm run build:window && npm run build:window-collision && npm run build:ax-element"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "babel-loader": "^10.0.0",
    "html-webpack-plugin": "^5.6.4",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  }
}
